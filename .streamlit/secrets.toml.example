# Copia questo file in `secrets.toml` (stessa cartella) e inserisci i valori.
# Il file `secrets.toml` NON viene committato (è in .gitignore).
# Su Streamlit Cloud questi valori vanno invece incollati in Settings > Secrets.

# Chiave Gemini — da Google AI Studio: https://aistudio.google.com/app/apikey
GEMINI_API_KEY = "LA_TUA_CHIAVE_QUI"

# Password di accesso all'app (scegline una robusta per la produzione)
APP_PASSWORD = "LA_TUA_PASSWORD_QUI"
